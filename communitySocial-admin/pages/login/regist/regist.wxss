/* 容器 */
.container {
  padding: 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #007bff;
}

/* 验证码输入框 */
.captcha-input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-image {
  width: 200rpx;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  background: #fafafa;
}

/* 选择器样式 */
.form-picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
}

.form-picker.placeholder {
  color: #999;
}

/* 按钮区域 */
.button-section {
  margin-bottom: 30rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  margin-bottom: 20rpx;
}

.back-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #fff;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: 2rpx solid #667eea;
}

/* 提示信息 */
.tips {
  text-align: center;
  padding: 20rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #ff9800;
  background: #fff3e0;
  padding: 15rpx 30rpx;
  border-radius: 10rpx;
  display: inline-block;
}
