<view class="container">
  <view class="header">
    <text class="title">社区管理员注册</text>
    <!-- <text class="subtitle">请填写基本信息进行注册</text> -->
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="label">手机号 *</text>
      <input 
        class="input" 
        type="number"
        value="{{formData.phone}}"
        bindinput="onInput"
        data-field="phone"
        placeholder="请输入手机号（11 位）"
        maxlength="11"
      />
    </view>

    <view class="form-item">
      <text class="label">密码 *</text>
      <input 
        class="input" 
        type="password"
        password
        value="{{formData.password}}"
        bindinput="onInput"
        data-field="password"
        placeholder="请输入密码（6-20 个字符）"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <text class="label">确认密码 *</text>
      <input 
        class="input" 
        type="password"
        password
        value="{{formData.confirmPassword}}"
        bindinput="onInput"
        data-field="confirmPassword"
        placeholder="请再次输入密码"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <text class="label">昵称 *</text>
      <input 
        class="input" 
        value="{{formData.nickname}}"
        bindinput="onInput"
        data-field="nickname"
        placeholder="请输入昵称"
        maxlength="50"
      />
    </view>

    <view class="form-item">
      <text class="label">验证码 *</text>
      <view class="captcha-input-wrapper">
        <input 
          class="input captcha-input" 
          type="text" 
          value="{{captchaCode}}"
          bindinput="onCaptchaInput"
          placeholder="请输入验证码"
          maxlength="4"
        />
        <image 
          class="captcha-image" 
          src="{{captchaImage}}" 
          mode="aspectFill"
          bindtap="refreshCaptcha"
        ></image>
      </view>
    </view>
  </view>

  <!-- <view class="tips-section">
    <text class="tips-title">温馨提示：</text>
    <text class="tips-content">注册成功后需完成实名认证并通过审核后方可使用管理功能</text>
  </view> -->

  <view class="button-section">
    <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}">提交注册</button>
    <button class="back-btn" bindtap="goBack">返回登录</button>
  </view>
</view>
