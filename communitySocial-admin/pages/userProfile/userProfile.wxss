/* pages/dashboard/userProfile/userProfile.wxss */
.user-profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 1000;
}

.loading-content {
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 头像区域 */
.avatar-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  position: relative;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: #fff;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-edit-tip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.tip-icon {
  font-size: 40rpx;
}

.tip-text {
  font-size: 20rpx;
  color: #fff;
}

.avatar-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.role-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
  align-self: flex-start;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-header .edit-btn {
  background-color: #667eea;
  color: #fff;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: auto;
  min-width: 120rpx;
  text-align: center;
}

.card-header .save-btn {
  background-color: #52c41a;
  color: #fff;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: auto;
  min-width: 60rpx;
  text-align: center;
}

.card-header .cancel-btn {
  background-color: #f0f0f0;
  color: #666;
  margin-right: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: auto;
  min-width: 60rpx;
  text-align: center;
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

/* 信息列表 */
.info-list {
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.item-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  padding: 12rpx 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  min-height: 40rpx;
}

.item-value.readonly {
  background-color: transparent;
  text-align: right;
  padding: 12rpx 0;
}

/* 社区信息特殊样式 */
.item-value.community-text {
  color: #667eea;
  font-weight: 500;
}

.picker-value {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 10rpx;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

/* 状态列表 */
.status-list {
  padding: 0 30rpx;
}

.status-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  color: #666;
  margin-right: 16rpx;
}

.status-value {
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-normal {
  background-color: #e6f7e6;
  color: #52c41a;
}

.status-banned {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.status-pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-abnormal {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.status-auth-0 {
  background-color: #f0f0f0;
  color: #666;
}

.status-auth-1 {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-auth-2 {
  background-color: #e6f7e6;
  color: #52c41a;
}

.status-auth-3 {
  background-color: #fff1f0;
  color: #ff4d4f;
}

/* 退出登录卡片 */
.logout-card {
  margin-top: 0;
  margin-bottom: 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  text-align: center;
}

.logout-btn::after {
  border: none;
}

/* 底部按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  border-radius: 12rpx;
}

/* 手机号显示和按钮 */
.item-value-with-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.phone-value {
  flex: 1;
  text-align: right;
}

.mini-btn,
.mini-btn::after {
  padding: 6rpx 12rpx !important;
  font-size: 24rpx !important;
  background-color: #667eea;
  color: #fff;
  border-radius: 6rpx;
  min-width: auto !important;
  width: auto !important;
  display: inline-block;
  line-height: 1.5;
  margin: 0 !important;
  border: none !important;
}

/* 账号安全列表 */
.security-list {
  padding: 0 30rpx;
}

.security-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.security-item:last-child {
  border-bottom: none;
}

.security-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.security-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.security-desc {
  font-size: 24rpx;
  color: #999;
}

.action-btn,
.action-btn::after {
  padding: 8rpx 16rpx !important;
  font-size: 26rpx !important;
  background-color: #667eea;
  color: #fff;
  border-radius: 8rpx;
  min-width: auto !important;
  width: auto !important;
  line-height: 1.5;
  margin: 0 !important;
  border: none !important;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-value {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #333;
}

.form-value.readonly {
  background-color: #f0f0f0;
  color: #666;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  min-width: auto;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #f0f0f0;
  color: #666;
}

.modal-btn.confirm {
  background-color: #667eea;
  color: #fff;
}
