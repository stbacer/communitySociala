/* pages/userAuth/userAuth.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 搜索区域 */
.search-box {
  display: flex;
  padding: 5rpx;
  background: white;
  border-bottom: 2rpx solid #eee;
  gap: 15rpx;  /* 减小间距 */
}

.search-input {
  flex: 1;  /* 自动占满剩余空间 */
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  min-width: 400rpx;  /* 增加最小宽度 */
}

.search-btn, .clear-btn {
  background-color: #1e88e5;
  color: white;
  border-radius: 50rpx;
  padding: 15rpx 20rpx !important;  /* 减小内边距 */
  font-size: 26rpx;                  /* 稍微调小字体 */
  border: none !important;
  width: auto !important;            /* 自动适应内容宽度 */
  min-width: unset !important;       /* 移除最小宽度限制 */
  white-space: nowrap;               /* 不换行 */
  line-height: 1;                  /* 调整行高 */
}

.clear-btn {
  background-color: #999;
}

/* 用户列表 */
.user-list {
  flex: 1;
  padding: 20rpx;
}

.user-item {
  margin-bottom: 20rpx;
  background: white;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-basic {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background-color: #eee;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.auth-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: #ffeb3b;
  color: #333;
}

.user-details {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 15rpx;
  font-size: 26rpx;
}

.label {
  color: #666;
  width: 160rpx;
}

.value {
  color: #333;
  flex: 1;
}

.quick-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-small {
  padding: 10rpx 18rpx !important;  /* 减小内边距 */
  font-size: 22rpx !important;      /* 调小字体 */
  border-radius: 8rpx;
  width: auto !important;           /* 自动适应内容宽度 */
  min-width: unset !important;      /* 移除最小宽度限制 */
  white-space: nowrap;              /* 不换行 */
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  max-height: 80vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.user-profile {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #eee;
}

.large-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 30rpx;
  background-color: #eee;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.profile-username {
  font-size: 26rpx;
  color: #666;
}

.auth-info .info-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-label {
  color: #666;
  width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.review-options {
  margin: 30rpx 0;
  padding: 20rpx 0;
  border-top: 2rpx solid #eee;
  border-bottom: 2rpx solid #eee;
}

.option-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.status-buttons {
  display: flex;
  gap: 20rpx;
}

.status-btn {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  background: white;
  color: #666;
  font-size: 28rpx;
}

.status-btn.active.approved {
  background: #4caf50;
  border-color: #4caf50;
  color: white;
}

.status-btn.active.rejected {
  background: #f44336;
  border-color: #f44336;
  color: white;
}

.remark-section {
  margin-top: 30rpx;
}

.remark-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.remark-input {
  width: 100% !important;           /* 确保占满宽度 */
  height: 120rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  min-width: unset !important;      /* 移除最小宽度限制 */
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 2rpx solid #eee;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  padding: 20rpx !important;        /* 减小内边距 */
  border-radius: 10rpx;
  font-size: 26rpx !important;      /* 调小字体 */
  width: auto !important;           /* 自动适应宽度 */
  min-width: unset !important;      /* 移除最小宽度限制 */
  max-width: unset !important;      /* 移除最大宽度限制 */
}

/* 工具类 */
.btn {
  border: none;
  border-radius: 8rpx;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-success {
  background-color: #4caf50;
  color: white;
}

.btn-danger {
  background-color: #f44336;
  color: white;
}

.btn-primary {
  background-color: #1e88e5;
  color: white;
}

.btn-default {
  background-color: #e0e0e0;
  color: #333;
}

/* 图片预览模态框 */
.image-preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.preview-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

.preview-swiper {
  width: 100%;
  height: 100%;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-controls {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
}

.preview-counter {
  color: white;
  font-size: 28rpx;
  background-color: rgba(0,0,0,0.5);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.preview-nav {
  display: flex;
  gap: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: rgba(255,255,255,0.3);
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: rgba(255,255,255,0.3);
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}