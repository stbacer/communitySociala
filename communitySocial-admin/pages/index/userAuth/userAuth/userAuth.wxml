<!--pages/userAuth/userAuth.wxml-->
<view class="container">
  <!-- 搜索区域 -->
  <view class="search-box">
    <input 
      class="search-input" 
      placeholder="搜索用户名或真实姓名" 
      bindinput="onSearchInput"
     value="{{searchKeyword}}"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
    <button class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch">清空</button>
  </view>

  <!-- 用户列表 -->
  <scroll-view class="user-list" scroll-y>
    <view 
      class="user-item card" 
      wx:for="{{userList}}" 
     wx:key="userId"
     bindtap="viewAuthDetail"
    data-user="{{item}}"
    >
      <view class="user-header">
        <view class="user-basic">
          <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarLoadError" data-userid="{{item.userId}}"></image>
          <view class="user-info">
            <text class="nickname">{{item.nickname}}</text>
          </view>
        </view>
        <view class="auth-status status-pending">待审核</view>
      </view>
      
      <view class="user-details">
        <view class="detail-row">
          <text class="label">手机号：</text>
          <text class="value">{{item.phone}}</text>
        </view>
        <view class="detail-row">
          <text class="label">申请时间：</text>
          <text class="value">{{item.formattedCreateTime}}</text>
        </view>
      </view>
      
      <!-- 快捷操作按钮 -->
      <view class="quick-actions">
        <button 
          class="btn btn-primary btn-small" 
         bindtap="viewAuthDetail"
        data-user="{{item}}"
        >查看详情</button>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{userList.length === 0 && !loading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无待审核的认证申请</text>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </scroll-view>

  <!-- 图片预览模态框 -->
  <view class="image-preview-modal" wx:if="{{showImagePreview}}" bindtap="closeImagePreview">
    <view class="preview-wrapper" catchtap="stopPropagation">
      <swiper 
        class="preview-swiper" 
        current="{{currentPreviewIndex}}"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{previewImages}}" wx:key="index">
          <image class="preview-image" src="{{item}}" mode="aspectFit"></image>
        </swiper-item>
      </swiper>
      
      <view class="preview-controls">
        <view class="preview-counter">
          {{currentPreviewIndex + 1}} / {{previewImages.length}}
        </view>
        <view class="preview-nav">
          <button class="nav-btn" bindtap="prevImage" wx:if="{{previewImages.length > 1}}">‹</button>
          <button class="nav-btn" bindtap="nextImage" wx:if="{{previewImages.length > 1}}">›</button>
        </view>
        <button class="close-preview" bindtap="closeImagePreview">×</button>
      </view>
    </view>
  </view>
</view>
