/* pages/postManage/postManage.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 搜索筛选区域 */
.search-filter {
  background: white;
  padding: 15rpx 20rpx;  /* 只保留左右 padding */
  margin: 0 0 20rpx 0;  /* 只保留下 margin，移除左右 margin */
  border-radius: 0;  /* 移除圆角 */
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.search-box {
  display: flex;
  margin-bottom: 15rpx;  /* 减小间距 */
  gap: 10rpx;  /* 添加间距 */
}

.search-input {
  flex: 1;
  padding: 12rpx 18rpx;  /* 减小内边距 */
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 26rpx;
  min-width: 350rpx;  /* 增加最小宽度 */
}

.search-btn {
  padding: 12rpx 18rpx !important;  /* 减小内边距 */
  background: #1e88e5;
  color: white;
  border-radius: 10rpx;
  font-size: 24rpx !important;  /* 调小字体 */
  border: none !important;
  width: auto !important;  /* 自动适应宽度 */
  min-width: unset !important;
  white-space: nowrap;
  line-height: 1.2;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 15rpx;  /* 减小间距 */
}

.type-picker {
  flex: 1;
}

.picker-display {
  padding: 12rpx 18rpx;  /* 减小内边距 */
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 24rpx;  /* 调小字体 */
  color: #333;
}

.reset-btn {
  padding: 12rpx 20rpx !important;  /* 减小内边距 */
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 24rpx !important;  /* 调小字体 */
  width: auto !important;  /* 自动适应宽度 */
  min-width: unset !important;
  white-space: nowrap;
  line-height: 1.2;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #e3f2fd;
  padding: 15rpx 20rpx;  /* 只保留左右 padding */
  margin: 0 0 15rpx 0;  /* 只保留下 margin，移除左右 margin */
  border-radius: 0;  /* 移除圆角 */
}

.batch-info {
  font-size: 24rpx;  /* 调小字体 */
  color: #1e88e5;
  font-weight: bold;
}

.batch-buttons {
  display: flex;
  gap: 10rpx;  /* 减小间距 */
}

.batch-btn {
  padding: 10rpx 16rpx !important;  /* 减小内边距 */
  border-radius: 8rpx;
  font-size: 22rpx !important;  /* 调小字体 */
  border: none !important;
  width: auto !important;  /* 自动适应宽度 */
  min-width: unset !important;
  white-space: nowrap;
}

.batch-btn.primary {
  background: #4caf50;
  color: white;
}

.batch-btn.danger {
  background: #f44336;
  color: white;
}

.batch-btn.cancel {
  background: #e0e0e0;
  color: #333;
}

/* 全选区域 */
.select-all {
  padding: 20rpx;
  background: #fafafa;
  border-bottom: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
}

/* 帖子复选框 */
.post-checkbox {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 10;
}

/* 标签页 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 2rpx solid #eee;
  margin: 0 0 20rpx 0;  /* 添加下 margin */
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1e88e5;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 6rpx;
  background: #1e88e5;
  border-radius: 3rpx;
}

/* 帖子列表 */
.post-list {
  flex: 1;
  padding: 20rpx;
}

.post-item {
  margin-bottom: 20rpx;
  background: white;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}

.post-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

/* 帖子类型标签 */
.post-type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: white;
}

.post-type-tag.type-1 {
  background-color: #2196f3;
}

.post-type-tag.type-2 {
  background-color: #ff9800;
}

.post-type-tag.type-3 {
  background-color: #4caf50;
}

.post-type-tag.type-4 {
  background-color: #9c27b0;
}

/* 二手交易标识 */
.secondhand-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8787);
  color: white;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
   opacity: 1;
  }
  50% {
   opacity: 0.8;
  }
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  margin-right: 15rpx;
  background-color: #eee;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.post-time {
  font-size: 22rpx;
  color: #999;
}

.post-status {
  font-size: 22rpx;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
}

.status-pending {
  background-color: #ffeb3b;
  color: #333;
}

.status-approved {
  background-color: #4caf50;
  color: white;
}

.status-rejected {
  background-color: #f44336;
  color: white;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 20rpx;
}

.post-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.post-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.post-image {
  width: 100%;
  height: 160rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
}

.post-image.single {
  height: 300rpx;
}

.location-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.location-icon {
  margin-right: 5rpx;
}

/* 帖子标签 */
.post-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.normal-tag {
  background-color: #e3f2fd;
  color: #1e88e5;
}

.anonymous-tag {
  background-color: #fce4ec;
  color: #e91e63;
}

.top-tag {
  background-color: #fff3e0;
  color: #ff9800;
}

/* 操作按钮 - 极简布局 */
.post-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  justify-content: center;
}

.action-btn {
  padding: 16rpx 32rpx !important;
  font-size: 28rpx !important;
  font-weight: bold;
  border-radius: 8rpx;
  border: none !important;
  width: auto !important;
  min-width: unset !important;
  white-space: nowrap;
  line-height: 1.3;
  transition: all 0.2s;
  flex: 1;
  max-width: 200rpx;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 按钮颜色 */
.btn-success {
  background-color: #4caf50;
  color: white;
}

.btn-success.btn-small {
  background-color: #e8f5e9;
  border-color: #c8e6c9 !important;
  color: #2e7d32 !important;
}

.btn-danger {
  background-color: #f44336;
  color: white;
}

.btn-danger.btn-small {
  background-color: #ffebee;
  border-color: #ffcdd2 !important;
  color: #c62828 !important;
}

.btn-primary {
  background-color: #1e88e5;
  color: white;
}

.btn-default {
  background-color: #e0e0e0;
  color: #333;
}

/* 审核历史模态框 */
.review-history-modal {
  max-height: 80vh;
}

.history-list {
  max-height: 50vh;
  overflow-y: auto;
}

.history-item {
  padding: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.history-item:last-child {
  border-bottom: none;
}

.history-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.reviewer {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.history-content {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: white;
  min-width: 80rpx;
  text-align: center;
}

.status-badge.approved {
  background-color: #4caf50;
}

.status-badge.rejected {
  background-color: #f44336;
}

.remark {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.empty-history {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 650rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  max-height: 85vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 65vh;
  overflow-y: auto;
}

/* 帖子详情 */
.post-detail {
  margin-bottom: 30rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background-color: #eee;
}

.detail-user-info {
  display: flex;
  flex-direction: column;
}

.detail-username {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.detail-time {
  font-size: 22rpx;
  color: #999;
}

.detail-content {
  background: #f9f9f9;
  border-radius: 15rpx;
  padding: 20rpx;
}

.detail-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.detail-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.detail-images {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.detail-image {
  width: 100%;
  border-radius: 10rpx;
  background-color: #eee;
}

/* 审核选项 */
.review-options {
  margin: 30rpx 0;
  padding: 20rpx 0;
  border-top: 2rpx solid #eee;
  border-bottom: 2rpx solid #eee;
}

.option-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.status-buttons {
  display: flex;
  gap: 20rpx;
}

.status-btn {
  flex: 1;
  padding: 18rpx !important;  /* 减小内边距 */
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  background: white;
  color: #666;
  font-size: 26rpx !important;  /* 调小字体 */
  width: auto !important;  /* 自动适应宽度 */
  min-width: unset !important;
}

.status-btn.active.approved {
  background: #4caf50;
  border-color: #4caf50;
  color: white;
}

.status-btn.active.rejected {
  background: #f44336;
  border-color: #f44336;
  color: white;
}

.remark-section {
  margin-top: 30rpx;
}

.remark-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.remark-input {
  width: 100% !important;  /* 确保占满宽度 */
  height: 100rpx;  /* 减小高度 */
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 15rpx;  /* 减小内边距 */
  font-size: 24rpx;  /* 调小字体 */
  box-sizing: border-box;
  min-width: unset !important;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 2rpx solid #eee;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  padding: 18rpx !important;  /* 减小内边距 */
  border-radius: 10rpx;
  font-size: 26rpx !important;  /* 调小字体 */
  width: auto !important;  /* 自动适应宽度 */
  min-width: unset !important;
  max-width: unset !important;
}