/* pages/postManage/postDetail/postDetail.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 帖子头部 */
.post-header {
  position: relative;
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
}

/* 二手交易信息 */
.secondhand-info {
  background: linear-gradient(135deg, #fff5e6 0%, #ffe6f0 100%);
  border: 2rpx solid #ffb3c6;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item-full {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 10rpx;
}

.info-item-full .label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.info-item-full .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.price-text {
  color: #ff4757;
  font-size: 32rpx;
  font-weight: bold;
}

.contact-text {
  color: #1e90ff;
  font-weight: 500;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-0 {
  background-color: #f0f0f0;
  color: #999;
}

.status-1 {
  background-color: #ff6b6b;
  color: #fff;
}

.status-2 {
  background-color: #51cf66;
  color: #fff;
}

/* 章节标题 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 帖子内容 */
.content-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 图片列表 */
.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
  margin-top: 20rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 12rpx;
}

.post-image {
  width: 100%;
  height: 100%;
}

/* 位置信息 */
.location-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.location-coords {
  display: flex;
  align-items: center;
  padding-top: 10rpx;
  border-top: 1rpx dashed #e5e5e5;
}

.coords-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.coords-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 审核信息 */
.info-item {
  display: flex;
  margin-bottom: 15rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.value.remark {
  color: #666;
  font-style: italic;
}

/* 底部操作按钮 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.btn::after {
  border: none;
}

.btn-danger {
  background-color: #ff6b6b;
  color: #fff;
}

.btn-success {
  background-color: #51cf66;
  color: #fff;
}

.btn-primary {
  background-color: #4dabf7;
  color: #fff;
}

.btn-default {
  background-color: #f0f0f0;
  color: #666;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(-50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.modal-body {
  padding: 30rpx;
}

.post-summary {
  margin-bottom: 30rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.review-options {
  margin-bottom: 25rpx;
}

.option-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.status-buttons {
  display: flex;
  gap: 20rpx;
}

.status-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  background-color: #f0f0f0;
  color: #666;
}

.status-btn.active {
  transform: scale(1.05);
}

.status-btn.active.approved {
  background-color: #51cf66;
  color: #fff;
}

.status-btn.active.rejected {
  background-color: #ff6b6b;
  color: #fff;
}

.remark-section {
  margin-top: 20rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.remark-input {
  width: 100%;
  height: 150rpx;
  padding: 15rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 图片预览模态框 */
.image-preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.preview-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.preview-swiper {
  width: 100%;
  height: 60vh;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-controls {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.preview-counter {
  font-size: 28rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}

.preview-nav {
  display: flex;
  gap: 60rpx;
}

.nav-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 用户信息卡片 */
.user-info-card {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border: 2rpx solid #90caf9;
}

.user-detail {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  transition: all 0.3s;
}

.user-detail:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.user-details {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.user-nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-meta {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
  background-color: rgba(255, 255, 255, 0.6);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: #999;
  margin-left: 10rpx;
  flex-shrink: 0;
}
