/* pages/dashboard/dashboard.wxss */
.dashboard-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%);
  color: white;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.user-details {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.role {
  font-size: 24rpx;
  opacity: 0.8;
}

.logout-btn {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 1rpx solid rgba(255, 255, 255, 0.3) !important;
  border-radius: 40rpx;
  padding: 12rpx 20rpx !important;
  font-size: 22rpx;
  display: inline-block;
  width: auto !important;
  min-width: unset;
  max-width: unset;
  white-space: nowrap;
  line-height: 1.2;
}

/* 统计概览 */
.stats-overview {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.icon-users {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
}

.icon-posts {
  background: linear-gradient(135deg, #2196f3 0%, #1565c0 100%);
  color: white;
}

.icon-reports {
  background: linear-gradient(135deg, #ff9800 0%, #ef6c00 100%);
  color: white;
}

.icon-total {
  background: linear-gradient(135deg, #9c27b0 0%, #6a1b9a 100%);
  color: white;
}

.icon-active {
  background: linear-gradient(135deg, #ff5722 0%, #d84315 100%);
  color: white;
}

.icon-today {
  background: linear-gradient(135deg, #00bcd4 0%, #00838f 100%);
  color: white;
}

.stat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 快捷操作 */
.quick-actions {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.actions-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.action-btn {
  width: 260rpx !important;
  height: 85rpx !important;
  min-width: unset !important;
  max-width: unset !important;
  border-radius: 10rpx;
  display: inline-flex !important;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: none !important;
  padding: 0 !important;
  margin: 0 auto;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
  line-height: 1.2;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%);
  color: white;
}

.btn-success {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
}

.btn-warning {
  background: linear-gradient(135deg, #ff9800 0%, #ef6c00 100%);
  color: white;
}

.btn-info {
  background: linear-gradient(135deg, #9c27b0 0%, #6a1b9a 100%);
  color: white;
}

/* 系统信息 */
.system-info .info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #eee;
}

.system-info .info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  background: white;
  padding: 40rpx 60rpx;
  border-radius: 20rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #333;
}
