/* pages/statistics/statistics.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部标题 */
.stats-header {
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 主要统计数据 */
.main-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.user-icon {
  font-size: 60rpx;
}

.post-icon {
  font-size: 60rpx;
}

.pending-post-icon {
  font-size: 60rpx;
}

.pending-user-icon {
  font-size: 60rpx;
}

.stat-info {
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 今日数据 */
.today-stats {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.today-cards {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.today-card {
  text-align: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 15rpx;
}

.today-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 10rpx;
}

.dau-value-large {
  font-size: 42rpx;
  color: #667eea;
}

.dau-card-highlight {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  position: relative;
  overflow: hidden;
}

.dau-card-highlight .today-label {
  color: rgba(255, 255, 255, 0.9);
}

.dau-trend-wrapper {
  margin-top: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.dau-trend {
  display: flex;
  align-items: center;
  gap: 5rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.dau-trend.trend-up {
  background: rgba(7, 193, 96, 0.2);
  color: #07c160;
}

.dau-trend.trend-down {
  background: rgba(250, 82, 82, 0.2);
  color: #fa5252;
}

.trend-icon {
  font-size: 24rpx;
}

.trend-value {
  font-size: 24rpx;
}

.trend-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.today-label {
  font-size: 24rpx;
  color: #666;
}

/* 用户发帖排行榜 */
.user-rankings {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rankings-list {
  margin-top: 20rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-number {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
  margin-right: 20rpx;
}

.ranking-number.top-three {
  font-size: 32rpx;
}

.ranking-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.ranking-info {
  flex: 1;
}

.ranking-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.ranking-count {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
}

.empty-data {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 热门板块分布 */
.category-section {
  margin: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.time-range-selector {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.range-btn {
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
}

.range-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.pie-chart-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.pie-chart-canvas {
  width: 600rpx;
  height: 600rpx;
}

.chart-legend {
  width: 100%;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.legend-item:last-child {
  border-bottom: none;
}

.legend-color {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.legend-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.legend-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.legend-value {
  font-size: 26rpx;
  color: #666;
}

/* DAU 趋势图 */
.dau-trend-section {
  margin: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.trend-chart-container {
  width: 100%;
  margin-top: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.dau-trend-canvas {
  width: 100%;
  height: 300px;
}
