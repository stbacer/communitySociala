/* pages/reportManage/reportDetail/reportDetail.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 举报详情 */
.report-detail {
  padding-bottom: 120rpx;
}

/* 通用区块样式 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 状态标签 */
.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: normal;
}

.status-pending {
  background-color: #ff9800;
  color: #fff;
}

.status-approved {
  background-color: #4caf50;
  color: #fff;
}

.status-rejected {
  background-color: #f44336;
  color: #fff;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.info-value.link {
  color: #007aff;
  text-decoration: underline;
}

.info-value.content-text {
  display: block;
  max-width: 100%;
  white-space: pre-wrap;
  word-wrap: break-word;
  line-height: 1.6;
}

/* 举报人信息 */
.reporter-info {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.reporter-info .info-row {
  display: flex;
  padding: 8rpx 0;
}

.reporter-info .hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 被举报内容 */
.target-content {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.target-content .info-row {
  display: flex;
  padding: 8rpx 0;
}

.btn-link {
  margin-top: 20rpx;
  background-color: #007aff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 16rpx 30rpx;
}

/* 举报原因 */
.reason-content {
  padding: 20rpx;
  background-color: #fff5f5;
  border-radius: 12rpx;
  margin-top: 10rpx;
  border-left: 4rpx solid #ff4444;
}

.reason-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.image-item {
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f0f0f0;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

/* 处理信息 */
.handle-info {
  padding: 20rpx;
  background-color: #f0f8ff;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.handle-info .info-row {
  display: flex;
  padding: 8rpx 0;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.btn-secondary {
  background-color: #f44336;
  color: #fff;
}

.btn-primary {
  background-color: #4caf50;
  color: #fff;
}

.btn-default {
  background-color: #e0e0e0;
  color: #333;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(-50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.modal-body {
  padding: 30rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 30rpx;
}

.status-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.status-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
  background-color: #fff;
  color: #666;
}

.status-btn.active.approved {
  background-color: #4caf50;
  color: #fff;
  border-color: #4caf50;
}

.status-btn.active.rejected {
  background-color: #f44336;
  color: #fff;
  border-color: #f44336;
}

.result-section {
  margin-top: 20rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.result-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
}

/* 图片预览 */
.image-preview {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.9);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1001;
}

.preview-content {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.preview-swiper {
  width: 100%;
  height: 70vh;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-nav {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 60rpx;
}

.preview-prev,
.preview-next {
  font-size: 32rpx;
  color: #fff;
  padding: 10rpx 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
}

.preview-index {
  font-size: 28rpx;
  color: #fff;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  font-size: 32rpx;
  color: #fff;
  padding: 10rpx 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
}
