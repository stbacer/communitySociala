/* pages/reportManage/reportManage.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 20rpx;
  background: white;
  margin: 0 20rpx 20rpx 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
}

.search-btn, .clear-btn {
  height: 60rpx !important;
  padding: 0 15rpx !important;
  border-radius: 8rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: unset !important;
  width: auto !important;
  line-height: normal !important;
}

.search-btn {
  background-color: #1e88e5;
  color: white;
  border: none;
}

.clear-btn {
  background-color: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
  margin-left: 10rpx;
}

/* 全选控制 */
.select-all-control {
  padding: 20rpx;
  background: white;
  border-bottom: 2rpx solid #eee;
}

.select-all-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

/* 批量操作栏 */
.batch-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #e3f2fd;
  border-bottom: 2rpx solid #bbdefb;
}

.batch-info {
  font-size: 26rpx;
  color: #1976d2;
  font-weight: bold;
}

.batch-buttons {
  display: flex;
  gap: 20rpx;
}

.batch-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
}

.batch-btn.primary {
  background: #1976d2;
  color: white;
}

.batch-btn.secondary {
  background: #4caf50;
  color: white;
}

/* 举报选择框 */
.report-checkbox {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 10;
}

/* 标签页 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 2rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1e88e5;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 6rpx;
  background: #1e88e5;
  border-radius: 3rpx;
}

/* 举报列表 */
.report-list {
  flex: 1;
  padding: 20rpx;
}

.report-item {
  margin-bottom: 20rpx;
  background: white;
  position: relative;
  padding-right: 80rpx; /* 为复选框留出空间 */
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.report-info {
  display: flex;
  flex-direction: column;
}

.report-id {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.report-time {
  font-size: 22rpx;
  color: #bbb;
}

.report-status {
  font-size: 22rpx;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
}

.status-pending {
  background-color: #ffeb3b;
  color: #333;
}

.status-approved {
  background-color: #4caf50;
  color: white;
}

.status-rejected {
  background-color: #f44336;
  color: white;
}

/* 举报内容 */
.report-content {
  margin-bottom: 20rpx;
}

.content-row {
  display: flex;
  margin-bottom: 15rpx;
  font-size: 26rpx;
}

.label {
  color: #666;
  width: 140rpx;
  flex-shrink: 0;
}

.value {
  color: #333;
  flex: 1;
}

.reason-text {
  color: #e91e63;
  font-weight: bold;
}

.target-content {
  background: #f9f9f9;
  padding: 15rpx;
  border-radius: 10rpx;
  line-height: 1.4;
}

/* 操作按钮 - 极简布局 */
.report-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  justify-content: center;
}

.action-btn {
  padding: 16rpx 32rpx !important;
  font-size: 28rpx !important;
  font-weight: bold;
  border-radius: 8rpx;
  border: none !important;
  width: auto !important;
  min-width: unset !important;
  white-space: nowrap;
  line-height: 1.3;
  transition: all 0.2s;
  flex: 1;
  max-width: 200rpx;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-success {
  background-color: #4caf50;
  color: white;
}

.btn-danger {
  background-color: #f44336;
  color: white;
}

.btn-primary {
  background-color: #1e88e5;
  color: white;
}

/* 处理记录 */
.handle-record {
  background: #f0f8ff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.record-item {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.record-label {
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.record-value {
  color: #333;
  flex: 1;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 650rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  max-height: 85vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 65vh;
  overflow-y: auto;
}

/* 举报详情 */
.report-detail {
  margin-bottom: 30rpx;
}

.detail-section {
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx dashed #eee;
}

.detail-section:last-child {
  border-bottom: none;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.detail-label {
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.detail-value {
  color: #333;
  flex: 1;
}

.content-text {
  background: #f9f9f9;
  padding: 15rpx;
  border-radius: 10rpx;
  line-height: 1.5;
}

.reason-text {
  display: block;
  color: #e91e63;
  font-weight: bold;
  padding: 15rpx;
  background: #fce4ec;
  border-radius: 10rpx;
  margin-top: 10rpx;
}

/* 处理选项 */
.handle-options {
  margin: 30rpx 0;
  padding: 20rpx 0;
  border-top: 2rpx solid #eee;
  border-bottom: 2rpx solid #eee;
}

.option-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.status-buttons {
  display: flex;
  gap: 20rpx;
}

.status-btn {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  background: white;
  color: #666;
  font-size: 28rpx;
}

.status-btn.active.approved {
  background: #4caf50;
  border-color: #4caf50;
  color: white;
}

.status-btn.active.rejected {
  background: #f44336;
  border-color: #f44336;
  color: white;
}

.result-section {
  margin-top: 30rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.result-input {
  width: 100%;
  height: 120rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 2rpx solid #eee;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.btn-default {
  background-color: #e0e0e0;
  color: #333;
}