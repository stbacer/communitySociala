/* 全局样式 */

/* 页面容器 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  /* align-items: center; */
  justify-content: space-between;
  padding: 20rpx 0;
  box-sizing: border-box;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn {
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  margin: 10rpx;
}

.btn-primary {
  background-color: #1e88e5;
  color: white;
}

.btn-success {
  background-color: #4caf50;
  color: white;
}

.btn-warning {
  background-color: #ff9800;
  color: white;
}

.btn-danger {
  background-color: #f44336;
  color: white;
}

.btn-default {
  background-color: #e0e0e0;
  color: #333;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.form-input {
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 列表样式 */
.list-item {
  padding: 30rpx;
  border-bottom: 2rpx solid #eee;
  background: white;
}

.list-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-status {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.status-pending {
  background-color: #ffeb3b;
  color: #333;
}

.status-approved {
  background-color: #4caf50;
  color: white;
}

.status-rejected {
  background-color: #f44336;
  color: white;
}

.item-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.item-meta {
  font-size: 24rpx;
  color: #999;
  display: flex;
  justify-content: space-between;
}

/* 统计卡片 */
.stat-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin: 20rpx;
  text-align: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 搜索框 */
.search-box {
  display: flex;
  padding: 20rpx;
  background: white;
  border-bottom: 2rpx solid #eee;
}

.search-input {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  background-color: #1e88e5;
  color: white;
  border-radius: 50rpx;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
}

/* 下拉刷新 */
.refresh-container {
  height: 100%;
}

/* 通用工具类 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.mt-10 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 20rpx;
}

.ml-10 {
  margin-left: 20rpx;
}

.mr-10 {
  margin-right: 20rpx;
}

.p-10 {
  padding: 20rpx;
}

.pt-10 {
  padding-top: 20rpx;
}

.pb-10 {
  padding-bottom: 20rpx;
}

.pl-10 {
  padding-left: 20rpx;
}

.pr-10 {
  padding-right: 20rpx;
}