/* pages/login/regist/regist.wxss */

.regist-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.optional {
  color: #999999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #cccccc;
}

/* 验证码输入框 */
.captcha-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.captcha-input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.captcha-input {
  flex: 1;
}

.captcha-image {
  width: 200rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.agreement-section {
  margin: 48rpx 0;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
}

checkbox {
  transform: scale(0.9);
  margin-right: 12rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.agreement-link {
  font-size: 26rpx;
  color: #667eea;
  text-decoration: underline;
}

.regist-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

.regist-btn[disabled] {
  background: #e0e0e0;
  color: #999999;
}

.loading-icon {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  vertical-align: middle;
  margin-right: 12rpx;
}

.back-to-login {
  text-align: center;
  margin-top: 32rpx;
}

.back-text {
  font-size: 28rpx;
  color: #666666;
}

.back-link {
  font-size: 28rpx;
  color: #667eea;
  margin-left: 8rpx;
  text-decoration: underline;
}
