/* pages/login/forgot-password/forgot-password.wxss */
.forgot-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-section {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.captcha-input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-image {
  width: 200rpx;
  height: 88rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e0e0e0;
}

.tip-section {
  background: #fff3cd;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.6;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.submit-btn[disabled] {
  background: #cccccc;
}

.loading-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.back-to-login {
  text-align: center;
}

.back-text {
  font-size: 28rpx;
  color: #666;
}

.back-link {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  margin-left: 8rpx;
}
