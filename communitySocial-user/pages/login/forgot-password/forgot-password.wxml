<!--pages/login/forgot-password/forgot-password.wxml-->
<view class="forgot-container">
  <view class="header-section">
    <text class="title">忘记密码</text>
    <text class="subtitle">验证手机号后重置密码</text>
  </view>

  <view class="form-section">
    <!-- 手机号输入 -->
    <view class="form-item">
      <view class="input-label">
        <text class="label-icon">📱</text>
        <text class="label-text">手机号</text>
      </view>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号"
        value="{{phoneNumber}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <!-- 图片验证码输入 -->
    <view class="form-item">
      <view class="input-label">
        <text class="label-icon">🔒</text>
        <text class="label-text">验证码</text>
      </view>
      <view class="captcha-input-wrapper">
        <input 
          class="input-field captcha-input" 
          type="text" 
          placeholder="请输入验证码"
          value="{{captchaCode}}"
          bindinput="onCaptchaInput"
          maxlength="4"
        />
        <image 
          class="captcha-image" 
          src="{{captchaImage}}" 
          mode="aspectFill"
          bindtap="refreshCaptcha"
        ></image>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tip-section">
      <text class="tip-text">重置后的密码将为手机号后 6 位数字</text>
    </view>

    <!-- 提交按钮 -->
    <button 
      class="submit-btn" 
      type="primary" 
      bindtap="onSubmitTap"
      disabled="{{!canSubmit || isSubmitting}}"
    >
      <block wx:if="{{!isSubmitting}}">
        <text>{{canSubmit ? '重置密码' : '请填写完整信息'}}</text>
      </block>
      <block wx:else>
        <loading class="loading-icon"></loading>重置中...
      </block>
    </button>

    <!-- 返回登录 -->
    <view class="back-to-login">
      <text class="back-text">记得密码？</text>
      <text class="back-link" bindtap="onBackToLogin">返回登录</text>
    </view>
  </view>
</view>
