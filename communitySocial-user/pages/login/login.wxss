/* pages/login/login.wxss */
.login-container {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  box-sizing: border-box;
}

.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  border-radius: 40rpx;
  background: white;
  padding: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-section {
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: #4caf50;
  border: none;
  margin-bottom: 30rpx;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #cccccc;
}

/* 账号密码登录按钮样式 */
.account-login-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  color: white;
  margin-top: 20rpx;
}

.account-login-btn::after {
  border: none;
}

.account-login-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.loading-icon {
  margin-right: 10rpx;
}

.divider {
  position: relative;
  text-align: center;
  margin: 40rpx 0;
}

.divider::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  position: relative;
  background: #667eea;
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.guest-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  color: white;
}

.guest-btn::after {
  border: none;
}

.guest-btn[disabled] {
  opacity: 0.6;
}

.agreement-section {
  margin-bottom: 40rpx;
  text-align: center;
}

.agreement-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: block;
}

.security-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
}

.features-section {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
}

.login-help {
  text-align: center;
  margin-top: 30rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.help-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.feature-item {
  width: 45%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  padding: 25rpx;
  border-radius: 20rpx;
  transition: transform 0.2s ease;
}

.feature-item:active {
  transform: scale(0.95);
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
}

.feature-text {
  font-size: 24rpx;
  color: white;
  text-align: center;
}