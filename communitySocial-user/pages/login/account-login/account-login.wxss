/* pages/login/account-login/account-login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  flex: 1;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 验证码输入框 */
.captcha-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-image {
  width: 200rpx;
  height: 88rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.form-options {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 40rpx;
}

.forget-password {
  font-size: 26rpx;
  color: #667eea;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.login-btn[disabled] {
  opacity: 0.7;
}

.switch-login {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
}

.switch-text {
  font-size: 26rpx;
  color: #666666;
}

.switch-link {
  font-size: 26rpx;
  color: #667eea;
  margin-left: 10rpx;
}

.other-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-text {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.other-icons {
  display: flex;
  gap: 40rpx;
}

.other-icon {
  width: 60rpx;
  height: 60rpx;
}

.agreement-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 10rpx;
}

.agreement-link {
  font-size: 24rpx;
  color: #ffd700;
  text-decoration: underline;
}

.loading-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}
