/* pages/index/index.wxss */
.home-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 筛选工具栏 */
.filter-bar {
  background: white;
  padding: 24rpx 80rpx 24rpx 20rpx;
  border-bottom: 2rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 98;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 隐藏按钮 */
.hide-filter-btn {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 99;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hide-filter-btn:active {
  opacity: 0.6;
  transform: translateY(-50%) scale(0.95);
}

.btn-icon.rotate-180 {
  transform: rotate(180deg);
  width: 32rpx;
  height: 32rpx;
}

/* 筛选工具栏隐藏状态 */
.filter-bar.hidden {
  display: none;
}

.filter-group {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

/* 第一个筛选组（类型）增加一些特殊处理 */
.filter-group:first-child {
  margin-bottom: 16rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  min-width: 80rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
  align-items: center;
}

/* 类型选项特殊样式 */
.type-options {
  gap: 10rpx;
}

.type-divider {
  width: 2rpx;
  height: 40rpx;
  background: #e0e0e0;
  margin: 0 10rpx;
}

.type-option-all {
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  min-width: 100rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.type-option {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 400;
  min-width: 120rpx;
  text-align: center;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.type-option.active,
.type-option-all.active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 229, 0.3);
}

.filter-option {
  padding: 10rpx 20rpx;
  margin: 0 10rpx 10rpx 0;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 20rpx;
  cursor: pointer;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}

.filter-option.active {
  background: #1e88e5;
  color: white;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 229, 0.3);
}

/* 排序信息提示 */
.sort-info {
  margin-left: 20rpx;
  display: flex;
  align-items: center;
}

.info-text {
  font-size: 22rpx;
  color: #ff9800;
  display: flex;
  align-items: center;
}

.info-text::before {
  content: '⚠️';
  margin-right: 10rpx;
}

/* 帖子容器 */
.posts-container {
  flex: 1;
  height: 100vh;
  position: relative;
}

.posts-list {
  padding: 20rpx;
  padding-top: 80rpx;  /* 为显示筛选按钮留出空间 */
}

/* 帖子项 */
.post-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.post-user-info {
  flex: 1;
}

/* 帖子标签容器 */
.post-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 置顶标签样式 */
.top-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.top-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.top-text {
  font-size: 22rpx;
  color: white;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.post-nickname {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.post-time {
  font-size: 22rpx;
  color: #999;
}

.post-type-tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: white;
  position: relative;
  z-index: 1;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.post-type-tag.type-1 {
  background: linear-gradient(135deg, #ff7043 0%, #ff5722 100%);
}

.post-type-tag.type-2 {
  background: linear-gradient(135deg, #66bb6a 0%, #4caf50 100%);
}

.post-type-tag.type-3 {
  background: linear-gradient(135deg, #42a5f5 0%, #2196f3 100%);
}

.post-type-tag.type-4 {
  background: linear-gradient(135deg, #ab47bc 0%, #9c27b0 100%);
}

/* 帖子距离显示 */
.post-distance {
  font-size: 22rpx;
  color: #1e88e5;
  margin-top: 10rpx;
  display: flex;
  align-items: center;
}

.distance-icon {
  margin-right: 5rpx;
  font-size: 20rpx;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 25rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.post-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: block;
  margin-bottom: 15rpx;
}

/* 帖子图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

/* 位置信息 */
.post-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.location-icon {
  margin-right: 10rpx;
}

.location-text {
  flex: 1;
}

.distance-text {
  color: #1e88e5;
}

/* 帖子操作 */
.post-actions {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
}

/* 热度排序指示器 */
.hot-indicator {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #ff5722;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
}

.fire-icon {
  margin-right: 4rpx;
  font-size: 18rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  padding: 10rpx 20rpx;
  transition: all 0.3s ease;
}

.action-btn.active {
  color: #1e88e5;
  transform: scale(1.1);
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 5rpx;
}

/* 加载状态 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more .loading-icon {
  margin-right: 10rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #bbb;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-more::before,
.no-more::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
  margin: 0 20rpx;
}

/* 显示筛选工具栏按钮 */
.show-filter-btn {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  z-index: 97;
}

/* 当筛选栏显示时，按钮也隐藏（因为筛选栏已经显示了） */
.show-filter-btn.show-filter-bar-visible {
  transform: translateY(-100%);
  opacity: 0;
  height: 0;
  padding: 0;
  overflow: hidden;
  border-bottom: none;
}

.show-filter-btn:active {
  background: #f5f5f5;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #666;
}
