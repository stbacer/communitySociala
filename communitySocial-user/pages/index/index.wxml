<!--pages/index/index.wxml-->
<view class="home-container">
  <!-- 显示筛选工具栏按钮（固定在顶部） -->
  <view class="show-filter-btn {{showFilterBar ? 'show-filter-bar-visible' : ''}}" bindtap="onToggleFilterBar">
    <image class="btn-icon" src="/images/down.png" mode="aspectFit"></image>
    <text class="btn-text">显示筛选</text>
  </view>
  
  <!-- 帖子列表 -->
  <scroll-view class="posts-container" scroll-y="true"
    refresher-enabled="true"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscroll="onPageScroll">
    
    <!-- 筛选工具栏 -->
    <view class="filter-bar {{showFilterBar ? '' : 'hidden'}}">
      <!-- 隐藏按钮 -->
      <view class="hide-filter-btn" bindtap="onToggleFilterBar">
        <image class="btn-icon rotate-180" src="/images/down.png" mode="aspectFit"></image>
      </view>
      
      <view class="filter-group">
        <text class="filter-label">类型:</text>
        <view class="filter-options type-options">
          <!-- 全部选项 -->
          <text 
            class="filter-option type-option-all {{selectedCategory === 'all' ? 'active' : ''}}" 
            data-category="all"
            bindtap="onFilterTypeChange"
          >全部</text>
          <view class="type-divider"></view>
          <!-- 动态渲染启用的分类 -->
          <block wx:for="{{categories}}" wx:key="categoryId">
            <text 
              wx:if="{{item.categoryId !== 'all'}}" 
              class="filter-option type-option {{selectedCategory === item.categoryId ? 'active' : ''}}" 
              data-category="{{item.categoryId}}"
              bindtap="onFilterTypeChange"
            >{{item.name}}</text>
          </block>
        </view>
      </view>
      
      <view class="filter-group">
        <text class="filter-label">排序:</text>
        <view class="filter-options">
          <text 
            class="filter-option {{filters.sortBy === 'time' ? 'active' : ''}}" 
            data-sort="time"
            bindtap="onSortChange"
          >最新</text>
          <text 
            class="filter-option {{filters.sortBy === 'hot' ? 'active' : ''}}" 
            data-sort="hot"
            bindtap="onSortChange"
          >最热</text>
          <text 
            class="filter-option {{filters.sortBy === 'nearby' ? 'active' : ''}}" 
            data-sort="nearby"
            bindtap="onSortChange"
          >附近</text>
        </view>
        <view class="sort-info" wx:if="{{filters.sortBy === 'nearby' && !currentLocation}}">
          <text class="info-text">⚠️ 需要开启定位权限</text>
        </view>
      </view>
    </view>
    
    <view class="posts-list">
      <block wx:for="{{posts}}" wx:key="postId">
        <view class="post-item" bindtap="goToPostDetail" data-id="{{item.postId}}">
          <!-- 帖子头部 -->
          <view class="post-header">
            <image 
              class="post-avatar" 
              src="{{item.avatarUrl || '/images/default-avatar.png'}}" 
              mode="aspectFill"
              bindtap="goToUserProfile"
              data-userid="{{item.userId}}"
              catchtap="true"
            ></image>
            <view class="post-user-info">
              <text class="post-nickname">{{item.nickname}}</text>
              <text class="post-time">{{item.publishTime}}</text>
            </view>
            <view class="post-tags">
              <!-- 置顶标签 -->
              <view class="top-tag" wx:if="{{item.isTop === 1}}">
                <text class="top-icon">📌</text>
                <text class="top-text">置顶</text>
              </view>
              <!-- 分类标签 -->
              <view class="post-type-tag type-{{item.categoryId}}">
                {{item.categoryName}}
              </view>
            </view>
          </view>


          
          <!-- 帖子内容 -->
          <view class="post-content">
            <text class="post-title">{{item.title}}</text>
            <text class="post-text">{{item.contentPreview}}</text>
            
            <!-- 帖子图片 -->
            <view class="post-images" wx:if="{{item.imageUrls && item.imageUrls.length > 0}}">
              <image 
                class="post-image" 
                wx:for="{{item.imageUrls}}" 
                wx:key="index"
                src="{{item}}" 
                mode="aspectFill"
              ></image>
            </view>
            
            <!-- 位置信息 -->
            <view class="post-location" wx:if="{{item.location}}">
              <text class="location-icon">📍</text>
              <text class="location-text">{{item.location}}</text>
              <text class="distance-text" wx:if="{{item.distance}}">{{item.formattedDistance}}</text>
            </view>
            
            <!-- 附近排序时的距离显示 -->
            <view class="post-distance" wx:if="{{filters.sortBy === 'nearby' && item.formattedDistance}}">
              <text class="distance-icon">🧭</text>
              <text>{{item.formattedDistance}}</text>
            </view>
          </view>

          <!-- 帖子操作 -->
          <view class="post-actions">
            <view 
              class="action-btn {{item.isLiked ? 'active' : ''}}" 
              catchtap="onLikePost"
              data-id="{{item.postId}}"
              data-index="{{index}}"
            >
              <image class="action-icon" src="{{item.isLiked ? '/images/likeY.png' : '/images/like.png'}}" mode="aspectFit"></image>
              <text>{{item.formattedLikeCount}}</text>
            </view>
            
            <view 
              class="action-btn {{item.isCollected ? 'active' : ''}}" 
              catchtap="onCollectPost"
              data-id="{{item.postId}}"
              data-index="{{index}}"
            >
              <image class="action-icon" src="{{item.isCollected ? '/images/favoriteY.png' : '/images/favorite.png'}}" mode="aspectFit"></image>
              <text>{{item.formattedCollectCount}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 加载状态 -->
    <view class="load-more" wx:if="{{loading}}">
      <view class="loading-icon">🔄</view>
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{posts.length === 0 && !loading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无帖子</text>
      <text class="empty-subtext">快去发布第一个帖子吧！</text>
    </view>
    
    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && posts.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
