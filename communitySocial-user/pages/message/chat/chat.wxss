/* pages/message/chat/chat.wxss */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.messages-scroll {
  flex: 1;
  height: 0;
  padding: 20rpx;
  box-sizing: border-box;
}

.messages-list {
  min-height: 100%;
  padding-bottom: 20rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

/* 消息行容器 */
.message-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

/* 系统消息居中显示 */
.message-row.system {
  justify-content: center;
  margin-bottom: 16rpx;
}

.system-content {
  max-width: 80%;
  text-align: center;
}

.system-text {
  display: block;
  font-size: 24rpx;
  color: #ff9800;
  background-color: #fff9e6;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ffd54f;
  line-height: 1.5;
}

/* 对方消息（左对齐） */
.message-row.left {
  justify-content: flex-start;
}

/* 自己消息（右对齐） */
.message-row.right {
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.message-row.left .avatar {
  margin-right: 16rpx;
}

.message-row.right .avatar {
  margin-left: 16rpx;
}

/* 消息内容容器 */
.message-wrapper {
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
}

.message-row.left .message-wrapper {
  align-items: flex-start;
}

.message-row.right .message-wrapper {
  align-items: flex-end;
}

/* 昵称（仅对方） */
.nickname {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  margin-left: 8rpx;
}

/* 气泡通用样式 */
.bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  word-wrap: break-word;
  word-break: break-all;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

/* 对方气泡 - 白色 */
.white-bubble {
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
}

/* 自己气泡 - 微信绿 */
.green-bubble {
  background-color: #95ec69;
  border: none;
}

/* 文本消息 */
.msg-text {
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
  display: block;
}

/* 图片消息 */
.msg-image {
  max-width: 400rpx;
  border-radius: 16rpx;
  display: block;
}

/* 时间戳 */
.time-stamp {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.left-time {
  text-align: left;
  margin-left: 8rpx;
}

.right-time {
  text-align: right;
  margin-right: 8rpx;
}

/* 底部输入栏 */
.input-bar {
  background-color: #fff;
  border-top: 2rpx solid #e5e5e5;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  /* 改为垂直布局 */
  display: flex;
  flex-direction: column;
}

/* 第一行：图片按钮行 */
.image-row {
  margin-bottom: 12rpx;
}

.image-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  background-color: transparent;
  border: none;
  font-size: 40rpx;
  transition: transform 0.2s;
}

.image-btn::after {
  border: none;
}

.image-btn:active {
  transform: scale(0.9);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.text-input {
  flex: 1;
  padding: 16rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  transition: all 0.3s;
}

.text-input:focus {
  background-color: #eeeeee;
}

.send-btn {
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #d1d0d0;
  color: #000;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s;
  flex-shrink: 0;
  white-space: nowrap;
  width: auto;
  min-width: 120rpx;
  max-width: 160rpx;
  box-sizing: border-box;
  text-align: center;
}

.send-btn::after {
  border: none;
}

.send-btn.active {
  background: linear-gradient(135deg, #1e88e5 0%, #1976d2 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(30, 136, 229, 0.3);
}

.send-btn.active:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.send-btn[disabled] {
  opacity: 0.6;
}

/* 系统通知提示 */
.system-tip {
  background-color: #fff;
  border-top: 2rpx solid #e5e5e5;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  text-align: center;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}
