/* pages/message/conversation-list/conversation-list.wxss */
.conversation-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.search-bar {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-search {
  padding: 0 10rpx;
  color: #999;
}

.search-btn {
  font-size: 26rpx;
  color: #1e88e5;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.conversations-scroll {
  flex: 1;
}

.conversations-list {
  background-color: #fff;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
  transition: background-color 0.2s;
}

.conversation-item:active {
  background-color: #f5f5f5;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.conversation-content {
  flex: 1;
  min-width: 0;
}

.conversation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.last-message {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.message-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.image-indicator {
  color: #999;
  font-style: italic;
}

.unread-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background-color: #ff4d4f;
  border-radius: 18rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.unread-badge text {
  font-size: 22rpx;
  color: #fff;
  padding: 0 8rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
