/* pages/profile/mycollections/mycollections.wxss */
.mycollections-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 页面头部 */
.header-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 30rpx 100rpx;
  position: relative;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  font-size: 40rpx;
  color: white;
  padding: 10rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

/* 滚动区域 */
.collections-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 0 30rpx;
}

/* 加载状态 */
.loading-section {
  padding: 30rpx;
}

.skeleton-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.skeleton-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #e0e0e0;
  margin-right: 20rpx;
}

.skeleton-info {
  flex: 1;
}

.skeleton-line {
  height: 24rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-content {
  margin-bottom: 20rpx;
}

.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-line.tiny {
  width: 100rpx;
  height: 20rpx;
}

/* 收藏列表 */
.collections-list {
  padding: 0 30rpx;
}

.collection-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.post-type-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: white;
  margin-bottom: 15rpx;
}

.help-tag {
  background: #2196f3;
}

.share-tag {
  background: #ff9800;
}

.info-tag {
  background: #4caf50;
}

.collection-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.collection-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.collection-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  height: 160rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
}

.more-images {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 22rpx;
  padding: 5rpx 10rpx;
  border-radius: 10rpx 0 10rpx 0;
}

.collection-time {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.time-label {
  color: #999;
  margin-right: 10rpx;
}

.time-value {
  color: #666;
}

.collection-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.collection-meta {
  display: flex;
  gap: 20rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.action-item .icon {
  font-size: 28rpx;
}

.action-item .count {
  font-size: 24rpx;
  color: #666;
}

.collection-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.collection-status.pending {
  background: #ffeb3b;
  color: #333;
}

.collection-status.approved {
  background: #4caf50;
  color: white;
}

.collection-status.rejected {
  background: #f44336;
  color: white;
}

/* 操作按钮 */
.collection-buttons {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  padding: 15rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

/* 空状态 */
.empty-section {
  text-align: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-subtext {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
