<!--pages/profile/account-settings/account-settings.wxml-->
<view class="settings-container">
  <!-- 修改昵称 -->
  <view class="settings-section">
    <view class="section-title">基本信息</view>
    <view class="settings-item" bindtap="onEditNickname">
      <text class="item-label">昵称</text>
      <view class="item-value">
        <text class="value-text">{{userInfo.nickname || '未设置'}}</text>
        <text class="arrow-icon">></text>
      </view>
    </view>
    
    <view class="settings-item" bindtap="onEditGender">
      <text class="item-label">性别</text>
      <view class="item-value">
        <text class="value-text">{{genderText}}</text>
        <text class="arrow-icon">></text>
      </view>
    </view>
    
    <view class="settings-item" bindtap="onEditSignature">
      <text class="item-label">个性签名</text>
      <view class="item-value">
        <text class="value-text signature-text">{{userInfo.signature || '未设置'}}</text>
        <text class="arrow-icon">></text>
      </view>
    </view>
  </view>
  
  <!-- 账号安全 -->
  <view class="settings-section">
    <view class="section-title">账号安全</view>
    <view class="settings-item" bindtap="onEditPhone">
      <text class="item-label">手机号</text>
      <view class="item-value">
        <text class="value-text">{{maskedPhone}}</text>
        <text class="arrow-icon">></text>
      </view>
    </view>
    
    <view class="settings-item" bindtap="onChangePassword">
      <text class="item-label">密码</text>
      <view class="item-value">
        <text class="value-text {{!hasPassword ? 'no-password' : ''}}">
          {{hasPassword ? '已设置' : '未设置'}}
        </text>
        <text class="arrow-icon">></text>
      </view>
    </view>
  </view>
  
  <!-- 底部提示 -->
  <view class="tips-section">
    <text class="tips-title">温馨提示：</text>
    <text class="tips-item">• 昵称修改后将立即生效</text>
    <text class="tips-item" wx:if="{{userInfo.phone}}">• 修改手机号需要验证原手机号</text>
    <text class="tips-item" wx:else>• 首次绑定手机号无需验证</text>
    <text class="tips-item">• 密码长度需在 6-20 个字符之间</text>
    <text class="tips-item">• 如忘记密码可联系管理员重置</text>
  </view>
</view>

<!-- 昵称编辑弹窗 -->
<view class="modal-mask" wx:if="{{showNicknameModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">修改昵称</text>
      <text class="modal-close" bindtap="closeNicknameModal">×</text>
    </view>
    <view class="modal-body">
      <input 
        class="modal-input" 
        type="text" 
        placeholder="请输入昵称（2-20 个字符）"
        value="{{nicknameInput}}"
        maxlength="20"
        bindinput="onNicknameInput"
        focus="{{showNicknameModal}}"
      />
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closeNicknameModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmEditNickname" disabled="{{!canSubmitNickname}}">确定</button>
    </view>
  </view>
</view>

<!-- 性别选择弹窗 -->
<view class="modal-mask" wx:if="{{showGenderModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">选择性别</text>
      <text class="modal-close" bindtap="closeGenderModal">×</text>
    </view>
    <view class="modal-body gender-options">
      <view 
        class="gender-option {{genderInput === 0 ? 'selected' : ''}}" 
        bindtap="onSelectGender" 
        data-gender="0"
      >
        <text class="gender-icon">🚻</text>
        <text class="gender-text">未知</text>
        <text class="gender-check" wx:if="{{genderInput === 0}}">✓</text>
      </view>
      <view 
        class="gender-option {{genderInput === 1 ? 'selected' : ''}}" 
        bindtap="onSelectGender" 
        data-gender="1"
      >
        <text class="gender-icon">♂️</text>
        <text class="gender-text">男</text>
        <text class="gender-check" wx:if="{{genderInput === 1}}">✓</text>
      </view>
      <view 
        class="gender-option {{genderInput === 2 ? 'selected' : ''}}" 
        bindtap="onSelectGender" 
        data-gender="2"
      >
        <text class="gender-icon">♀️</text>
        <text class="gender-text">女</text>
        <text class="gender-check" wx:if="{{genderInput === 2}}">✓</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closeGenderModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmEditGender">确定</button>
    </view>
  </view>
</view>

<!-- 个性签名编辑弹窗 -->
<view class="modal-mask" wx:if="{{showSignatureModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">修改个性签名</text>
      <text class="modal-close" bindtap="closeSignatureModal">×</text>
    </view>
    <view class="modal-body">
      <textarea 
        class="modal-textarea" 
        placeholder="请输入个性签名（最多 100 个字符）"
        value="{{signatureInput}}"
        maxlength="100"
        bindinput="onSignatureInput"
        focus="{{showSignatureModal}}"
        auto-height
      />
      <view class="char-count">{{signatureInput.length}}/100</view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closeSignatureModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmEditSignature" disabled="{{!canSubmitSignature}}">确定</button>
    </view>
  </view>
</view>

<!-- 修改手机号弹窗 -->
<view class="modal-mask" wx:if="{{showPhoneModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">{{hasPhone ? '修改手机号' : '绑定手机号'}}</text>
      <text class="modal-close" bindtap="closePhoneModal">×</text>
    </view>
    <view class="modal-body">
      <!-- 已绑定手机号，需要验证当前手机号 -->
      <view class="form-item" wx:if="{{hasPhone}}">
        <text class="form-label">当前手机号</text>
        <input 
          class="form-input" 
          type="number"
          maxlength="11"
          placeholder="请输入当前手机号以验证身份"
          value="{{currentPhoneInput}}"
          bindinput="onCurrentPhoneInput"
        />
      </view>
      <!-- 新手机号 -->
      <view class="form-item">
        <text class="form-label">{{hasPhone ? '新手机号' : '手机号'}}</text>
        <input 
          class="form-input" 
          type="number"
          maxlength="11"
          placeholder="{{hasPhone ? '请输入新手机号' : '请输入手机号'}}"
          value="{{phoneInput}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closePhoneModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmEditPhone" disabled="{{!canSubmitPhone}}">确定</button>
    </view>
  </view>
</view>

<!-- 修改密码弹窗 -->
<view class="modal-mask" wx:if="{{showPasswordModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">{{hasPassword ? '修改密码' : '设置密码'}}</text>
      <text class="modal-close" bindtap="closePasswordModal">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item" wx:if="{{hasPassword}}">
        <text class="form-label">原密码</text>
        <input 
          class="form-input" 
          type="text"
          password="{{true}}"
          placeholder="请输入原密码"
          value="{{oldPasswordInput}}"
          bindinput="onOldPasswordInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">新密码</text>
        <input 
          class="form-input" 
          type="text"
          password="{{true}}"
          maxlength="20"
          placeholder="请输入新密码（6-20 位）"
          value="{{newPasswordInput}}"
          bindinput="onNewPasswordInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">确认密码</text>
        <input 
          class="form-input" 
          type="text"
          password="{{true}}"
          maxlength="20"
          placeholder="请再次输入新密码"
          value="{{confirmPasswordInput}}"
          bindinput="onConfirmPasswordInput"
        />
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closePasswordModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmChangePassword" disabled="{{!canSubmitPassword}}">确定</button>
    </view>
  </view>
</view>
