<!--pages/profile/other/other.wxml-->
<view class="user-profile-container">
  <!-- 用户信息头部 -->
  <view class="user-header-section">
    <view class="header-content">
      <image 
        class="user-avatar" 
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" 
        mode="aspectFill"
      ></image>
      <view class="user-info">
        <text class="user-nickname">{{userInfo.nickname || '未知用户'}}</text>
        <text class="user-signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</text>
        <view class="user-stats">
          <view class="stat-item">
            <text class="stat-num">{{stats.postCount || 0}}</text>
            <text class="stat-label">帖子</text>
          </view>
          <view class="stat-item">
            <text class="stat-num">{{stats.followerCount || 0}}</text>
            <text class="stat-label">粉丝</text>
          </view>
          <view class="stat-item">
            <text class="stat-num">{{stats.followingCount || 0}}</text>
            <text class="stat-label">关注</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 关注按钮 -->
    <view class="follow-action" wx:if="{{!isSelf}}">
      <button 
        class="follow-btn {{isFollowed ? 'followed' : ''}}" 
        bindtap="onToggleFollow"
      >
        {{isFollowed ? '已关注' : '关注'}}
      </button>
    </view>
  </view>

  <!-- 页面标签切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === 0 ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="0"
    >
      TA 的帖子
    </view>
    <view 
      class="tab-item {{currentTab === 1 ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="1"
    >
      TA 的关注
    </view>
    <view 
      class="tab-item {{currentTab === 2 ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="2"
    >
      TA 的粉丝
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view 
    class="content-scroll" 
    scroll-y="true" 
    bindscrolltolower="onScrollToLower"
    lower-threshold="50"
    refresher-enabled="true"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <!-- 帖子列表 -->
    <view class="content-section" wx:if="{{currentTab === 0}}">
      <!-- 加载状态 -->
      <view class="loading-section" wx:if="{{loading && posts.length === 0}}">
        <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="index">
          <view class="skeleton-header">
            <view class="skeleton-avatar"></view>
            <view class="skeleton-info">
              <view class="skeleton-line short"></view>
              <view class="skeleton-line"></view>
            </view>
          </view>
          <view class="skeleton-content">
            <view class="skeleton-line"></view>
            <view class="skeleton-line"></view>
            <view class="skeleton-line short"></view>
          </view>
        </view>
      </view>

      <!-- 帖子列表 -->
      <view class="posts-list" wx:if="{{posts.length > 0}}">
        <block wx:for="{{posts}}" wx:key="postId">
          <view class="post-item" bindtap="onPostTap" data-postid="{{item.postId}}">
            <view class="post-header">
              <view class="post-type-tag type-{{item.categoryId}}">
                {{item.categoryName || '未知分类'}}
              </view>
              <text class="post-time">{{item.publishTime}}</text>
            </view>
            
            <view class="post-title">{{item.title}}</view>
            <view class="post-preview">{{item.content}}</view>
            
            <view class="post-images" wx:if="{{item.imageUrls && item.imageUrls.length > 0}}">
              <block wx:for="{{item.imageUrls.slice(0, 3)}}" wx:key="index">
                <image 
                  class="preview-image" 
                  src="{{item}}" 
                  mode="aspectFill"
                ></image>
              </block>
              <view class="more-images" wx:if="{{item.imageUrls.length > 3}}">
                <text>+{{item.imageUrls.length - 3}}</text>
              </view>
            </view>
            
            <view class="post-footer">
              <view class="post-actions">
                <view class="action-item">
                  <text class="icon">👍</text>
                  <text class="count">{{item.likeCount}}</text>
                </view>
                <view class="action-item">
                  <text class="icon">💬</text>
                  <text class="count">{{item.commentCount}}</text>
                </view>
                <view class="action-item">
                  <text class="icon">👁️</text>
                  <text class="count">{{item.viewCount}}</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 空状态 -->
      <view class="empty-section" wx:if="{{!loading && posts.length === 0}}">
        <image class="empty-icon" src="/images/empty-posts.png" mode="aspectFit"></image>
        <text class="empty-text">暂无帖子</text>
      </view>
    </view>

    <!-- 关注列表 -->
    <view class="content-section" wx:if="{{currentTab === 1}}">
      <view class="user-list" wx:if="{{followingList.length > 0}}">
        <block wx:for="{{followingList}}" wx:key="userId">
          <view class="user-list-item" bindtap="onUserTap" data-userid="{{item.userId}}">
            <image 
              class="list-user-avatar" 
              src="{{item.avatarUrl || '/images/default-avatar.png'}}" 
              mode="aspectFill"
            ></image>
            <view class="list-user-info">
              <text class="list-user-nickname">{{item.nickname}}</text>
              <text class="list-user-desc" wx:if="{{item.signature}}">{{item.signature}}</text>
            </view>
            <button 
              class="mini-follow-btn {{item.isFollowed ? 'followed' : ''}}"
              catchtap="onToggleFollowUser"
              data-userid="{{item.userId}}"
              data-index="{{index}}"
            >
              {{item.isFollowed ? '已关注' : '关注'}}
            </button>
          </view>
        </block>
      </view>
          
      <view class="empty-section" wx:if="{{!loading && followingList.length === 0}}">
        <image class="empty-icon" src="/images/empty-posts.png" mode="aspectFit"></image>
        <text class="empty-text">暂无关注</text>
      </view>
    </view>

    <!-- 粉丝列表 -->
    <view class="content-section" wx:if="{{currentTab === 2}}">
      <view class="user-list" wx:if="{{followerList.length > 0}}">
        <block wx:for="{{followerList}}" wx:key="userId">
          <view class="user-list-item" bindtap="onUserTap" data-userid="{{item.userId}}">
            <image 
              class="list-user-avatar" 
              src="{{item.avatarUrl || '/images/default-avatar.png'}}" 
              mode="aspectFill"
            ></image>
            <view class="list-user-info">
              <text class="list-user-nickname">{{item.nickname}}</text>
              <text class="list-user-desc" wx:if="{{item.signature}}">{{item.signature}}</text>
            </view>
            <button 
              class="mini-follow-btn {{item.isFollowed ? 'followed' : ''}}"
              catchtap="onToggleFollowUser"
              data-userid="{{item.userId}}"
              data-index="{{index}}"
            >
              {{item.isFollowed ? '已关注' : '关注'}}
            </button>
          </view>
        </block>
      </view>
      
      <view class="empty-section" wx:if="{{!loading && followerList.length === 0}}">
        <image class="empty-icon" src="/images/empty-posts.png" mode="aspectFit"></image>
        <text class="empty-text">暂无粉丝</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{posts.length > 0 || followingList.length > 0 || followerList.length > 0}}">
      <view wx:if="{{hasMore}}">
        <loading></loading>
        <text>正在加载更多...</text>
      </view>
      <view wx:else>
        <text>没有更多了</text>
      </view>
    </view>
  </scroll-view>
</view>
