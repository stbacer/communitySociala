/* pages/profile/auth/auth.wxss */
.auth-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.auth-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 15rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 认证表单 */
.auth-form {
  background: white;
  border-radius: 15rpx;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 25rpx 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1.5;
  height: auto;
  min-height: 80rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1e88e5;
}

.form-picker {
  position: relative;
  display: flex;
  align-items: center;
}

.form-picker.placeholder {
  color: #999;
}

.form-picker.disabled-picker {
  background-color: #f5f5f5;
  color: #ccc;
  pointer-events: none;
}

/* 社区选择器提示 */
.community-hint {
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  background-color: #f9f9f9;
  color: #999;
  font-size: 28rpx;
  text-align: center;
}

/* 身份证明图片上传区域 */
.identity-upload-area {
  margin-top: 15rpx;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.uploaded-image {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #f44336;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.upload-hint {
  font-size: 20rpx;
  color: #bbb;
}

.upload-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.upload-status loading {
  margin-right: 10rpx;
}

.identity-tips {
  background: #fff8e1;
  border-left: 6rpx solid #ffc107;
  padding: 15rpx;
  border-radius: 8rpx;
  margin-top: 15rpx;
}

.identity-tips .tip-item {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
  display: block;
}

.identity-tips .tip-item:last-child {
  margin-bottom: 0;
}

/* 认证须知 */
.auth-tips {
  background: white;
  border-radius: 15rpx;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.auth-tips .tip-item {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.auth-tips .tip-item:before {
  content: "• ";
  color: #1e88e5;
  margin-right: 10rpx;
}

/* 底部操作按钮 */
.footer-actions {
  padding: 0 20rpx;
  margin-top: 30rpx;
}

.submit-btn {
  width: 100%;
  padding: 25rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  background: #1e88e5;
  color: white;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #cccccc;
  color: #999999;
}

.submit-btn[disabled] {
  background: #cccccc;
  color: #999999;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  color: white;
  font-size: 28rpx;
}

.loading-overlay loading {
  margin-bottom: 20rpx;
}