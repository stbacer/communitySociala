/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息区域 */
.user-info-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.user-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.avatar-container {
  position: relative;
  margin-right: 25rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: block;
}

.avatar-edit-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-container:active .avatar-edit-mask {
  opacity: 1;
}

.camera-icon {
  font-size: 36rpx;
  color: white;
  margin-bottom: 5rpx;
}

.edit-text {
  font-size: 20rpx;
  color: white;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.user-signature {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 15rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.auth-status {
  display: flex;
  align-items: center;
}

.auth-badge {
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: white;
  margin-right: 15rpx;
}

.auth-action {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: underline;
}

.auth-action.disabled {
  color: rgba(255, 255, 255, 0.5);
}

.edit-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 10rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  padding: 25rpx 0;
}

.stat-item {
  text-align: center;
}

/* 帖子统计项可点击样式 */
.stat-item:nth-child(1) {
  cursor: pointer;
  position: relative;
}

.stat-item:nth-child(1):active {
  opacity: 0.7;
  transform: scale(0.95);
  transition: all 0.2s ease;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能菜单区域 */
.menu-section {
  background: white;
  border-radius: 15rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.menu-list {
  padding: 0 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 设置区域 */
.settings-section {
  background: white;
  border-radius: 15rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.settings-list {
  padding: 0 30rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.setting-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

/* 退出登录区域 */
.logout-section {
  padding: 0 20rpx;
}

.logout-btn {
  width: 100%;
  background: white;
  color: #f44336;
  border: 2rpx solid #f44336;
  border-radius: 15rpx;
  padding: 25rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.logout-btn::after {
  border: none;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  color: white;
  font-size: 28rpx;
}

.loading-overlay loading {
  margin-bottom: 20rpx;
}