<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- 用户信息区域 -->
  <view class="user-info-section">
    <view class="user-header">
      <view class="avatar-container" bindtap="onChangeAvatar">
        <image 
          class="user-avatar" 
          src="{{userInfo.avatarUrl}}" 
          mode="aspectFill"
          binderror="onAvatarError"
        ></image>
        <view class="avatar-edit-mask">
          <text class="camera-icon">📷</text>
          <text class="edit-text">更换头像</text>
        </view>
      </view>
      <view class="user-details">
        <text class="user-nickname">{{userInfo.nickname || '微信用户'}}</text>
        <text class="user-signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</text>
        <view class="auth-status">
          <text 
            class="auth-badge" 
            style="background-color: {{authStatusColor[authStatus]}}"
          >
            {{authStatusText[authStatus]}}
          </text>
          <text 
            class="auth-action" 
            bindtap="onAuthActionTap"
            data-status="{{authStatus}}"
            data-cooldown="{{authCooldown}}"
          >
            <block wx:if="{{authStatus === 0}}">
              <block wx:if="{{authCooldown > 0}}">
                {{authCooldown}}秒后可重新认证
              </block>
              <block wx:else>
                立即认证
              </block>
            </block>
            <block wx:elif="{{authStatus === 1}}">
              审核中
            </block>
            <block wx:elif="{{authStatus === 2}}">
              查看详情
            </block>
            <block wx:else>
              重新认证
            </block>
          </text>
        </view>
      </view>
    </view>
    
    <view class="user-stats">
      <view class="stat-item" bindtap="onGoToMyPosts">
        <text class="stat-number">{{stats.postCount}}</text>
        <text class="stat-label">帖子</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.likeCount}}</text>
        <text class="stat-label">获赞</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.followerCount}}</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.followingCount}}</text>
        <text class="stat-label">关注</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单区域 -->
  <view class="menu-section">
    <view class="menu-list">
      <block wx:for="{{menuItems}}" wx:key="id">
        <view class="menu-item" bindtap="onMenuItemTap" data-id="{{item.id}}">
          <view class="menu-icon">{{item.icon}}</view>
          <view class="menu-content">
            <text class="menu-title">{{item.title}}</text>
            <text class="menu-desc">{{item.desc}}</text>
          </view>
          <text class="arrow">→</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="settings-section">
    <view class="settings-list">
      <!-- <view class="setting-item" bindtap="onContactSupport">
        <text class="setting-icon">📞</text>
        <text class="setting-text">联系客服</text>
        <text class="arrow">→</text>
      </view> -->
      <!-- <view class="setting-item" bindtap="onShareAppMessage">
        <text class="setting-icon">📱</text>
        <text class="setting-text">分享应用</text>
        <text class="arrow">→</text>
      </view> -->
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <loading></loading>
    <text>加载中...</text>
  </view>
</view>