/* pages/profile/myposts/myposts.wxss */

.myposts-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 调试相关样式 */
.debug-btn {
  background-color: #ff6b6b;
  color: white;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

.debug-info {
  background-color: #fff3cd;
  border: 1rpx solid #ffeaa7;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 10rpx;
}

.debug-info text {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #856404;
}

.debug-info button {
  margin: 10rpx 10rpx 0 0;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

/* 页面头部样式 */
.header-section {
  background-color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  height: 88rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  height: 88rpx;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
  padding: 10rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.placeholder {
  width: 40rpx;
}

/* 内容滚动区域 */
.posts-scroll {
  flex: 1;
  padding: 20rpx;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-section text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 骨架屏样式 */
.skeleton-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.skeleton-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-right: 20rpx;
}

.skeleton-info {
  flex: 1;
}

.skeleton-content {
  margin-bottom: 20rpx;
}

.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.skeleton-actions {
  display: flex;
  gap: 30rpx;
}

.skeleton-line {
  height: 20rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.skeleton-line:last-child {
  margin-bottom: 0;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-line.tiny {
  width: 80rpx;
  height: 16rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 帖子列表 */
.posts-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单个帖子项 */
.post-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.post-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 帖子头部 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-type-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
  font-weight: 500;
}

.help-tag {
  background-color: #ff6b6b;
}

.share-tag {
  background-color: #4ecdc4;
}

.info-tag {
  background-color: #45b7d1;
}

.post-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.pending {
  background-color: #ffd93d;
  color: #333;
}

.approved {
  background-color: #6bcf7f;
  color: #fff;
}

.rejected {
  background-color: #ff6b6b;
  color: #fff;
}

/* 帖子标题 */
.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 帖子内容预览 */
.post-preview {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 图片预览 */
.post-images {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.more-images {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-images text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 帖子底部信息 */
.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.post-meta .publish-time {
  font-size: 24rpx;
  color: #999;
}

.post-actions {
  display: flex;
  gap: 30rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-item .icon {
  font-size: 28rpx;
}

.action-item .count {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.post-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.btn {
  flex: 1;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background-color: #007aff;
  color: #fff;
  border-radius: 30rpx;
  padding: 0 40rpx;
  height: 60rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.load-more view {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 响应式适配 */
@media screen and (max-width: 750rpx) {
  .post-item {
    padding: 25rpx;
  }
  
  .post-title {
    font-size: 30rpx;
  }
  
  .post-preview {
    font-size: 26rpx;
  }
  
  .preview-image {
    width: 160rpx;
    height: 160rpx;
  }
  
  .more-images {
    width: 160rpx;
    height: 160rpx;
  }
}