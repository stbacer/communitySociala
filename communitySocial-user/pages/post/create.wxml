<!--pages/post/create.wxml-->
<view class="create-container">
  <!-- 帖子类型（板块）选择 -->
  <view class="section">
    <view class="section-title">选择板块</view>
    <picker 
      class="type-picker" 
      mode="selector" 
      range="{{categories}}" 
      range-key="name"
      value="{{selectedCategoryIndex}}"
      bindchange="onSelectCategory"
    >
      <view class="picker-display">
        <text wx:if="{{selectedCategoryIndex > -1}}">{{categories[selectedCategoryIndex].name}}</text>
        <text wx:else class="placeholder">请选择板块</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 标题输入 -->
  <view class="section">
    <view class="section-title">帖子标题</view>
    <input 
      class="form-input title-input" 
      placeholder="请输入帖子标题（5-50 个字符）" 
      value="{{formData.title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
    <view class="char-count">{{formData.title.length}}/50</view>
  </view>

  <!-- 内容输入 -->
  <view class="section">
    <view class="section-title">详细内容</view>
    <textarea 
      class="form-textarea" 
      style="height: {{textareaHeight}}"
      placeholder="请输入帖子详细内容（10-1000 个字符）" 
      value="{{formData.content}}"
      bindinput="onContentInput"
      maxlength="1000"
      auto-height
    />
    <view class="char-count">{{formData.content.length}}/1000</view>
  </view>

  <!-- 图片上传 -->
  <view class="section">
    <view class="section-title">添加图片</view>
    <view class="image-upload-area">
      <view class="uploaded-images">
        <view 
          class="uploaded-image" 
          wx:for="{{formData.imageUrls}}" 
          wx:key="index"
        >
          <image class="image-preview" src="{{item}}" mode="aspectFill"></image>
          <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">×</view>
        </view>
        
        <view 
          class="upload-btn {{formData.imageUrls.length >= maxImages ? 'disabled' : ''}}" 
          bindtap="onChooseImage"
          wx:if="{{formData.imageUrls.length < maxImages}}"
        >
          <text class="upload-icon">+</text>
          <text class="upload-text">添加图片</text>
          <text class="upload-hint">{{formData.imageUrls.length}}/{{maxImages}}</text>
        </view>
      </view>
      
      <view class="upload-status" wx:if="{{uploading}}">
        <loading></loading>
        <text>图片上传中...</text>
      </view>
    </view>
  </view>

  <!-- 位置信息 -->
  <view class="section">
    <view class="section-title">位置信息</view>
    <view class="location-selector">
      <block wx:if="{{formData.location}}">
        <view class="selected-location">
          <text class="location-text">{{formData.location.address || formData.location.name}}</text>
          <text class="clear-location" bindtap="onClearLocation">×</text>
        </view>
      </block>
      
      <block wx:else>
        <button class="select-location-btn" bindtap="onSelectLocation">
          <text class="btn-icon">📍</text>
          <text>选择位置</text>
        </button>
      </block>
      
      <view class="location-tip">
        <text>选择位置可以让附近的邻居更容易看到您的帖子</text>
      </view>
    </view>
  </view>

  <!-- 匿名发布 -->
  <view class="section">
    <view class="section-title">发布设置</view>
    <view class="setting-item">
      <text class="setting-label">匿名发布</text>
      <switch 
        class="setting-switch" 
        checked="{{formData.isAnonymous}}" 
        bindchange="onToggleAnonymous"
      />
    </view>
    <view class="setting-desc">
      <text>开启匿名发布后，其他人将看不到您的真实身份</text>
    </view>
  </view>

  <!-- 二手交易信息（当选择二手交易板块时显示） -->
  <view class="section" wx:if="{{selectedCategoryId == 2}}">
    <view class="section-title">二手交易信息</view>
    
    <!-- 价格输入 -->
    <view class="form-item">
      <view class="form-item-label">
        <text class="required-mark">*</text>
        <text>物品价格（元）</text>
      </view>
      <input 
        class="form-input" 
        type="digit"
        placeholder="请输入转让价格" 
        value="{{secondHandData.price}}"
        bindinput="onPriceInput"
        maxlength="10"
      />
    </view>

    <!-- 交易方式选择 -->
    <view class="form-item">
      <view class="form-item-label">
        <text class="required-mark">*</text>
        <text>交易方式</text>
      </view>
      <picker 
        mode="selector" 
        range="{{transactionModes}}" 
        value="{{secondHandData.transactionMode === 1 ? 0 : (secondHandData.transactionMode === 2 ? 1 : 2)}}"
        bindchange="onTransactionModeChange"
      >
        <view class="picker-display">
          <text wx:if="{{secondHandData.transactionMode === 1}}">仅支持自提</text>
          <text wx:elif="{{secondHandData.transactionMode === 2}}">仅支持快递</text>
          <text wx:else>自提和快递均可</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 联系方式输入 -->
    <view class="form-item">
      <view class="form-item-label">
        <text class="required-mark">*</text>
        <text>联系方式</text>
      </view>
      <input 
        class="form-input" 
        type="text"
        placeholder="请输入手机号或微信号" 
        value="{{secondHandData.contactInfo}}"
        bindinput="onContactInfoInput"
        maxlength="20"
      />
    </view>

    <view class="trade-tip">
      <text>💡 提示：请如实填写价格和联系方式，方便买卖双方沟通</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <!-- <button class="action-btn save-draft-btn" bindtap="onSaveDraft">保存草稿</button> -->
    <button class="action-btn reset-btn" bindtap="onReset">重置</button>
    <button 
      class="action-btn submit-btn" 
      bindtap="onSubmit"
      disabled="{{isSubmitting}}"
    >
      <block wx:if="{{!isSubmitting}}">发布帖子</block>
      <block wx:else>
        <loading class="loading-icon"></loading>发布中...
      </block>
    </button>
  </view>
  
  <!-- 页面状态提示 -->
  <view class="page-status" wx:if="{{pageState.errorMessage}}">
    <text class="error-message">⚠️ {{pageState.errorMessage}}</text>
  </view>
  
  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{pageState.isLoading}}">
    <view class="loading-content">
      <loading></loading>
      <text>加载中...</text>
    </view>
  </view>
</view>
