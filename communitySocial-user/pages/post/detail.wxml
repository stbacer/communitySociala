<!--pages/post/detail.wxml-->
<view class="detail-container">
  <!-- 帖子详情 -->
  <scroll-view class="content-container" scroll-y="true">
    <block wx:if="{{postDetail}}">
      <!-- 帖子头部 -->
      <view class="post-header">
        <image 
          class="author-avatar" 
          src="{{postDetail.avatarUrl || '/images/default-avatar.png'}}" 
          mode="aspectFill"
          bindtap="onAuthorAvatarTap"
          data-userid="{{postDetail.userInfo && postDetail.userInfo.userId && postDetail.userInfo.userId !== '' ? postDetail.userInfo.userId : ''}}"
          data-nickname="{{postDetail.isAnonymous == 1 ? '匿名用户' : (postDetail.userInfo && postDetail.userInfo.nickname ? postDetail.userInfo.nickname : '未知用户')}}"
        ></image>
        <view class="author-info">
          <text class="author-name">{{postDetail.isAnonymous == 1 ? '匿名用户' : (postDetail.userInfo && postDetail.userInfo.nickname ? postDetail.userInfo.nickname : '未知用户')}}</text>
          <text class="post-time">{{postDetail.formattedPublishTime || postDetail.publishTime}}</text>
        </view>
        <view class="send-message-btn" 
              wx:if="{{postDetail.isAnonymous != 1 && postDetail.userInfo && postDetail.userInfo.userId && postDetail.userInfo.userId !== userInfo.userId}}" 
              bindtap="onSendMessageTap"
              data-userid="{{postDetail.userInfo && postDetail.userInfo.userId && postDetail.userInfo.userId !== '' ? postDetail.userInfo.userId : ''}}"
              data-nickname="{{postDetail.userInfo && postDetail.userInfo.nickname ? postDetail.userInfo.nickname : '未知用户'}}">
          💬 发消息
        </view>
        <view class="post-type-tag type-{{postDetail.type}}">
          {{['', '普通', '求助', '二手', '活动'][postDetail.type]}}
        </view>
      </view>

      <!-- 帖子内容 -->
      <view class="post-content">
        <text class="post-title">{{postDetail.title}}</text>
        <text class="post-text">{{postDetail.content}}</text>
        
        <!-- 帖子图片 -->
        <view class="post-images" wx:if="{{postDetail.imageUrls && postDetail.imageUrls.length > 0}}">
          <image 
            class="post-image" 
            wx:for="{{postDetail.imageUrls}}" 
            wx:key="index"
            src="{{item}}" 
            mode="widthFix"
            bindtap="previewImage"
            data-url="{{item}}"
            data-urls="{{postDetail.imageUrls}}"
          ></image>
        </view>
        
        <!-- 位置信息 -->
        <view class="post-location" wx:if="{{postDetail.location}}">
          <text class="location-icon">📍</text>
          <text class="location-text">{{postDetail.location}}</text>
          <text class="distance-text" wx:if="{{postDetail.distanceText}}">距您 {{postDetail.distanceText}}</text>
        </view>
        
        <!-- 发布时间 -->
        <view class="post-publish-time">
          <text class="time-text">发布时间： {{postDetail.formattedPublishTime || postDetail.publishTime}}</text>
        </view>
      </view>
      
      <!-- 二手交易信息（仅当帖子类型为二手交易时显示）-->
      <view class="second-hand-info" wx:if="{{postDetail.categoryId == 2}}">
        <view class="section-title">
          <text class="section-icon">🛒</text>
          <text>交易信息</text>
        </view>
              
        <!-- 价格 -->
        <view class="trade-item price-section">
          <text class="trade-label">价格</text>
          <text class="trade-price">￥{{postDetail.price}}</text>
        </view>
              
        <!-- 交易方式 -->
        <view class="trade-item" wx:if="{{postDetail.transactionMode}}">
          <text class="trade-label">交易方式</text>
          <text class="trade-value">{{postDetail.transactionMode == 1 ? '仅支持自提' : (postDetail.transactionMode == 2 ? '仅支持快递' : '自提和快递均可')}}</text>
        </view>
              
        <!-- 联系方式 -->
        <view class="trade-item contact-section" wx:if="{{postDetail.contactInfo}}">
          <text class="trade-label">联系方式</text>
          <view class="contact-wrapper">
            <text class="contact-value">{{postDetail.contactInfo}}</text>
            <text class="copy-btn" bindtap="onCopyContact">复制</text>
          </view>
        </view>
        
        <!-- 立即购买按钮（仅当帖子类型为二手交易且当前用户不是卖家时显示）-->
        <!-- <view 
          class="buy-now-action" 
          wx:if="{{postDetail.userId !== userInfo.userId}}"
        >
          <button class="buy-now-btn" bindtap="onBuyNow">
            🛒 立即购买
          </button>
        </view> -->
      </view>



      <!-- 帖子操作 -->
      <view class="post-actions">
        <!-- 编辑和删除按钮（仅作者可见） -->
        <view 
          class="action-btn edit-btn" 
          wx:if="{{userInfo && postDetail && userInfo.userId === postDetail.userId}}"
          bindtap="onEditPost"
        >
          <text class="action-icon">✏️</text>
          <text>编辑</text>
        </view>
        <view 
          class="action-btn delete-btn" 
          wx:if="{{userInfo && postDetail && userInfo.userId === postDetail.userId}}"
          catchtap="onDeletePost"
        >
          <text class="action-icon">🗑️</text>
          <text>删除</text>
        </view>
        
        <!-- 普通操作按钮 -->
        <view 
          class="action-btn {{postDetail.isLiked ? 'active' : ''}}" 
          bindtap="onLikePost"
        >
          <image class="action-icon" src="{{postDetail.isLiked ? '/images/likeY.png' : '/images/like.png'}}" mode="aspectFit"></image>
          <text>{{postDetail.formattedLikeCount || '0'}}</text>
        </view>
        
        <view class="action-btn" bindtap="onShowCommentInput">
          <image class="action-icon" src="/images/comment.png" mode="aspectFit"></image>
          <text>{{postDetail.formattedCommentCount || '0'}}</text>
        </view>
        
        <view 
          class="action-btn {{postDetail.isCollected ? 'active' : ''}}" 
          bindtap="onCollectPost"
        >
          <image class="action-icon" src="{{postDetail.isCollected ? '/images/favoriteY.png' : '/images/favorite.png'}}" mode="aspectFit"></image>
          <text>{{postDetail.formattedCollectCount || '0'}}</text>
        </view>
        
        <view class="action-btn" bindtap="onShowReport">
          <image class="action-icon" src="/images/report.png" mode="aspectFit"></image>
          <text>举报</text>
        </view>
        
      </view>
    </block>

    <!-- 评论区域 -->
    <view class="comments-section">
      <view class="section-header">
        <text class="section-title">全部评论 ({{comments.length}})</text>
      </view>
      
      <view class="comments-list">
        <block wx:for="{{comments}}" wx:key="commentId">
          <view class="comment-item">
            <!-- 评论头部 -->
            <view class="comment-header">
              <image 
                class="comment-avatar" 
                src="{{item.avatarUrl || '/images/default-avatar.png'}}" 
                mode="aspectFill"
                bindtap="onCommentAvatarTap"
                data-userid="{{item.userId}}"
                data-nickname="{{item.nickname}}"
              ></image>
              <view class="comment-user-info">
                <text class="comment-nickname">{{item.nickname}}</text>
                <text class="comment-time">{{item.formattedCreateTime || item.createTime}}</text>
              </view>
              <view class="comment-actions">
                <text 
                  class="reply-btn" 
                  bindtap="onShowCommentInput"
                  data-comment="{{item}}"
                >回复</text>
                <text 
                  class="edit-btn" 
                  wx:if="{{item.userId === userInfo.userId}}"
                  bindtap="onEditComment"
                  data-comment="{{item}}"
                  data-index="{{index}}"
                >编辑</text>
                <text 
                  class="delete-btn" 
                  wx:if="{{item.userId === userInfo.userId}}"
                  bindtap="onDeleteComment"
                  data-id="{{item.commentId}}"
                  data-index="{{index}}"
                >删除</text>
                <text 
                  class="report-btn" 
                  wx:if="{{item.userId !== userInfo.userId}}"
                  bindtap="onReportComment"
                  data-comment="{{item}}"
                >举报</text>
              </view>
            </view>

            <!-- 评论内容 -->
            <view class="comment-content">
              <!-- 回复提示 -->
              <view class="reply-to" wx:if="{{item.parentComment}}">
                <text>回复 @{{item.parentComment.nickname}}：</text>
              </view>
              
              <!-- 长评论处理 -->
              <view class="comment-text-wrapper">
                <text 
                  class="comment-text {{(item.content.length > 100 && !expandedComments[item.commentId]) ? 'collapsed' : ''}}"
                >{{item.content}}</text>
                
                <!-- 展开/收起按钮 -->
                <text 
                  class="expand-btn" 
                  wx:if="{{item.content.length > 100}}"
                  bindtap="toggleCommentExpand"
                  data-id="{{item.commentId}}"
                >
                  {{expandedComments[item.commentId] ? '收起' : '展开'}}
                </text>
              </view>
            </view>

            <!-- 评论操作 -->
            <view class="comment-footer">
              <view 
                class="like-btn {{item.isLiked ? 'active' : ''}}" 
                bindtap="onLikeComment"
                data-id="{{item.commentId}}"
                data-index="{{index}}"
              >
                <text class="like-icon">👍</text>
                <text>{{item.likeCount}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 加载状态 -->
      <view class="load-more" wx:if="{{loading}}">
        <loading></loading>
        <text>加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{comments.length === 0 && !loading}}">
        <text class="empty-icon">💬</text>
        <text class="empty-text">暂无评论，快来抢沙发吧！</text>
      </view>
      
      <!-- 没有更多 -->
      <view class="no-more" wx:if="{{!hasMore && comments.length > 0}}">
        <text>没有更多评论了</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部评论输入框 -->
  <view class="comment-input-container" wx:if="{{showCommentInput}}">
    <view class="comment-input-overlay" bindtap="onHideCommentInput"></view>
    <view class="comment-input-panel">
      <view class="input-header">
        <text class="input-title">
          {{editingComment ? '编辑评论' : (replyToComment ? '回复 @' + replyToComment.nickname : '发表评论')}}
        </text>
        <text class="close-btn" bindtap="onHideCommentInput">×</text>
      </view>
      
      <textarea 
        class="comment-textarea" 
        placeholder="{{editingComment ? '编辑评论内容...' : (replyToComment ? '回复内容...' : '说点什么...')}}"
        value="{{commentContent}}"
        bindinput="onCommentInput"
        bindfocus="onCommentFocus"
        bindblur="onCommentBlur"
        maxlength="500"
        focus="{{showCommentInput}}"
        show-confirm-bar="{{true}}"
        confirm-type="send"
        bindconfirm="onSubmitComment"
        auto-height="{{true}}"
        fixed="{{true}}"
      />
      
      <!-- 输入框工具栏 -->
      <view class="input-toolbar" wx:if="{{showCommentInput}}">
        <view class="toolbar-left">
          <text class="emoji-btn" bindtap="onInsertEmoji" data-emoji="😊">😊</text>
          <text class="emoji-btn" bindtap="onInsertEmoji" data-emoji="👍">👍</text>
          <text class="emoji-btn" bindtap="onInsertEmoji" data-emoji="❤️">❤️</text>
        </view>
        <view class="toolbar-right">
          <text 
            class="clear-btn" 
            bindtap="onClearComment"
            wx:if="{{commentContent.length > 0}}"
          >清空</text>
        </view>
      </view>
      
      <view class="input-footer">
        <text class="char-count">{{commentContent.length}}/500</text>
        <button 
          class="submit-btn {{(!commentContent || commentContent.trim().length === 0) ? 'disabled' : ''}}" 
          bindtap="onSubmitComment"
          disabled="{{isSubmittingComment || !commentContent || commentContent.trim().length === 0}}"
        >
          <block wx:if="{{!isSubmittingComment}}">
            {{editingComment ? '保存' : '发送'}}
          </block>
          <block wx:else>
            {{editingComment ? '保存中...' : '发送中...'}}
          </block>
        </button>
      </view>
    </view>
  </view>

  <!-- 举报弹窗 -->
  <view class="modal-overlay" wx:if="{{showReportModal}}" bindtap="onCloseReport">
    <view class="report-modal" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title">举报帖子</text>
        <text class="close-btn" bindtap="onCloseReport">×</text>
      </view>
      
      <view class="modal-body">
        <text class="reason-title">请输入举报原因：</text>
        <textarea 
          class="reason-input" 
          placeholder="请详细描述违规内容，如：该帖子包含虚假广告、色情低俗等内容..."
          value="{{reportReason}}"
          bindinput="onReportReasonInput"
          maxlength="200"
          auto-height
          fixed-height
        />
        <text class="char-count">{{reportReason.length}}/200</text>
      </view>
      
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="onCloseReport">取消</button>
        <button 
          class="confirm-btn" 
          bindtap="onSubmitReport"
          disabled="{{!reportReason || reportReason.trim().length === 0}}"
        >提交举报</button>
      </view>
    </view>
  </view>
</view>